<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="XRayView"
    Language="1033"
    Version="$(var.ProductVersion)"
    Manufacturer="XRayView"
    UpgradeCode="4EED743C-C600-4DAA-B6A5-87626F2A9E3D">
    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" Platform="x64" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of XRayView is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLDIR" Name="XRayView" />
      </Directory>
    </Directory>

    <Feature Id="MainFeature" Title="XRayView" Level="1">
      <ComponentGroupRef Id="AppFiles" />
    </Feature>
  </Product>
</Wix>
